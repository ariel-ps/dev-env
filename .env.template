# dev-env environment variables
# Copy relevant lines to ~/.zshrc and fill in values.
# Required vars must be set; optional vars have defaults shown.

# ── ps-agent ────────────────────────────────────────────────────────────
# Tenant domain and app-id the local agent uses (from MDM plist or config.toml).
# pa-api will auto-resolve these from the agent install if not set here.
export PROMPT_API_DOMAIN=""          # e.g. acme.prompt.security
export PROMPT_API_KEY=""             # app-id UUID from the tenant

# Used as default email in pa-api get-policy / check (falls back to $USER).
export PROMPT_USER_EMAIL=""          # e.g. you@acme.com

# Reported in pa-api sensor data. Optional — defaults to "dev".
# export PROMPT_AGENT_VERSION=""

# Frontegg session token for ps-known-site (copy from browser DevTools cookies).
# Short-lived — re-export each session when needed.
# export PROMPT_JWT=""

# ── intune ──────────────────────────────────────────────────────────────
# Azure AD app registration with DeviceManagementManagedDevices.Read.All
# (+ PrivilegedOperations.All for `intune sync`). Application permissions,
# admin-consented. Create at: portal.azure.com → Azure AD → App registrations.
export INTUNE_TENANT_ID=""           # Azure AD tenant GUID
export INTUNE_CLIENT_ID=""           # app registration client ID
export INTUNE_CLIENT_SECRET=""       # client secret value (not the secret ID)

# ── jenkins ─────────────────────────────────────────────────────────────
# Used by scripts/jenkins/bin/download-artifact.sh.
export JENKINS_URL=""                # e.g. https://jenkins.example.com
export JENKINS_USER=""               # Jenkins username
export JENKINS_TOKEN=""              # Jenkins API token

# ── docker / hermes-webui ───────────────────────────────────────────────
# All optional — defaults shown.
# export HERMES_WEBUI_DIR=""         # default: ~/.local/share/hermes-webui
# export HERMES_HOME=""              # default: ~/.hermes
# export HERMES_WORKSPACE=""         # default: ~/workspace

# ── docker / openspec-ui ────────────────────────────────────────────────
# export OPENSPEC_UI_DIR=""          # default: ~/.local/share/openspec-ui
# export OPENSPEC_UI_PORT=""         # default: 3000

# ── ps-platform ─────────────────────────────────────────────────────────
# export PS_PLATFORM_REPO=""         # default: prompt-security/ps-platform
# export PS_PLATFORM_IMAGE_WORKFLOW="" # default: build-push-docker-image-ps-platform.yml
